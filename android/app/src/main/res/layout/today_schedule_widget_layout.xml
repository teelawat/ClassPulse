<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_light_background"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Header Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_day_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ตารางเรียนวันนี้"
            android:textColor="#FF1E293B"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignBaseline="@id/widget_day_title"
            android:text="ClassPulse"
            android:textColor="#FF64748B"
            android:textSize="10sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FFE2E8F0"
        android:layout_marginBottom="8dp"/>

    <!-- Placeholder for Empty Schedule -->
    <TextView
        android:id="@+id/widget_placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="ไม่มีเรียนในวันนี้ 🎉"
        android:textColor="#FF64748B"
        android:textSize="13sp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Class Rows Container -->
    <LinearLayout
        android:id="@+id/widget_rows_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Row 1 -->
        <RelativeLayout
            android:id="@+id/row1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/slot1_badge"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/slot1_subject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="วิชาที่ 1"
                    android:textColor="#FF0F172A"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/slot1_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="00:00 - 00:00 น."
                    android:textColor="#FF64748B"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/slot1_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/widget_badge_current_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="กำลังเรียน"
                android:textColor="#FF1B5E20"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Row 1 Divider -->
        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="0.8dp"
            android:background="#FFF1F5F9"
            android:layout_marginVertical="6dp"/>

        <!-- Row 2 -->
        <RelativeLayout
            android:id="@+id/row2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/slot2_badge"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/slot2_subject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="วิชาที่ 2"
                    android:textColor="#FF0F172A"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/slot2_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="00:00 - 00:00 น."
                    android:textColor="#FF64748B"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/slot2_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/widget_badge_next_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="ถัดไป"
                android:textColor="#FFE65100"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Row 2 Divider -->
        <View
            android:id="@+id/divider2"
            android:layout_width="match_parent"
            android:layout_height="0.8dp"
            android:background="#FFF1F5F9"
            android:layout_marginVertical="6dp"/>

        <!-- Row 3 -->
        <RelativeLayout
            android:id="@+id/row3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/slot3_badge"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/slot3_subject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="วิชาที่ 3"
                    android:textColor="#FF0F172A"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/slot3_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="00:00 - 00:00 น."
                    android:textColor="#FF64748B"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/slot3_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/widget_badge_next_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="ถัดไป"
                android:textColor="#FFE65100"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

    </LinearLayout>

</LinearLayout>
